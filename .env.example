# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
# Set exactly one of the following:
POSTGRES_DB=                  # single database backup (pg_dump)
# POSTGRES_BACKUP_ALL=true    # full cluster backup (pg_dumpall)
# POSTGRES_EXTRA_OPTS=        # extra flags passed to pg_dump, e.g. --exclude-table-data=logs

# ── S3 storage ────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_PREFIX=backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
# AWS_ENDPOINT_URL=           # set for non-AWS providers, e.g. http://minio:9000

# ── Schedule ──────────────────────────────────────────────────────────────────
BACKUP_CRON_SCHEDULE=0 2 * * *

# ── Sanity checks ────────────────────────────────────────────────────────────
# SANITY_CHECK_DISABLE=true            # set to skip all startup checks
# SANITY_CHECK_PG_RETRIES=3            # PostgreSQL TCP connection attempts
# SANITY_CHECK_PG_RETRY_DELAY=2        # seconds between retries
# SANITY_CHECK_SKIP_S3_WRITE_PROBE=true # skip S3 write+delete permission probe
